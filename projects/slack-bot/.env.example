# Slack Bot Tokens (from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key

# CourtListener (optional — for case research tools)
COURTLISTENER_TOKEN=your-courtlistener-token

# Channel routing (use channel names or IDs)
SLACK_CHANNEL_STATUS=#status
SLACK_CHANNEL_RESEARCH=#research
SLACK_CHANNEL_ADVERSARIAL=#adversarial

# Morning digest schedule (24h, server-local time)
DIGEST_HOUR=7
DIGEST_MINUTE=0
